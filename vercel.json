{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/(.*\\.(js|css|html|png|jpg|svg|ico))", "dest": "public/$1" },
    { "src": "/", "dest": "public/index.html" },
    { "src": "/milestone.html", "dest": "public/milestone.html" }
  ]
}
